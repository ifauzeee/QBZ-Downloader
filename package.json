{
  "name": "qbz-downloader",
  "version": "5.3.0",
  "description": "Desktop-first Qobuz downloader EXE with Hi-Res audio, metadata automation, and lyrics support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "build:full": "npm run sync-version && cd client && npm ci && npm run build && cd .. && npm run build",
    "clean": "rimraf dist coverage",
    "copy-assets": "copyfiles -u 1 \"src/services/dashboard/public/**/*\" dist",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "sync-version": "node scripts/sync-version.js",
    "test": "npm run test:native && npx vitest run",
    "test:native": "npm rebuild better-sqlite3",
    "test:watch": "npx vitest",
    "test:coverage": "npx vitest run --coverage",
    "test:smoke": "node tests/electron-smoke.mjs",
    "bundle-binaries": "node scripts/bundle-binaries.cjs",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "docs": "typedoc --out docs src/index.ts",
    "desktop:rebuild": "node scripts/rebuild-electron-native.cjs",
    "desktop:start": "npm run build:full && npm run desktop:rebuild && electron electron/main.cjs",
    "desktop:pack": "npm run build:full && npm run desktop:rebuild && electron-builder --dir",
    "desktop:dist": "npm run desktop:dist:win",
    "desktop:dist:win": "npm run build:full && npm run desktop:rebuild && electron-builder --win nsis",
    "desktop:dist:portable": "npm run build:full && npm run desktop:rebuild && electron-builder --win portable",
    "desktop:dist:mac": "npm run build:full && npm run desktop:rebuild && electron-builder --mac dmg zip",
    "desktop:dist:linux": "npm run build:full && npm run desktop:rebuild && electron-builder --linux AppImage deb tar.gz",
    "desktop:dist:all": "npm run build:full && npm run desktop:rebuild && electron-builder --win nsis portable --mac dmg zip --linux AppImage deb tar.gz",
    "prepare": "husky"
  },
  "keywords": [
    "qobuz",
    "downloader",
    "hi-res",
    "flac",
    "music",
    "metadata",
    "lyrics",
    "lossless",
    "audio",
    "music-downloader",
    "hifi",
    "desktop-app",
    "electron",
    "windows-exe"
  ],
  "author": "ifauzeee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ifauzeee/QBZ-Downloader.git"
  },
  "bugs": {
    "url": "https://github.com/ifauzeee/QBZ-Downloader/issues"
  },
  "homepage": "https://github.com/ifauzeee/QBZ-Downloader#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "build": {
    "appId": "com.ifauze.qbzdownloader",
    "productName": "QBZ Downloader",
    "directories": {
      "output": "release",
      "buildResources": "assets/desktop"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/desktop/**/*",
      "node_modules/**/*",
      "package.json",
      "LICENSE",
      "README.md"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "asarUnpack": [
      "**/*.node",
      "node_modules/better-sqlite3/**/*"
    ],
    "extraResources": [
      "bin/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/desktop/icon.ico",
      "artifactName": "QBZ-Downloader-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.music",
      "icon": "assets/desktop/icon.png",
      "artifactName": "QBZ-Downloader-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Audio;AudioVideo;Music",
      "maintainer": "ifauze",
      "icon": "assets/desktop/icon.png",
      "artifactName": "QBZ-Downloader-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "QBZ-Downloader-Portable-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ifauzeee",
        "repo": "QBZ-Downloader",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/desktop/icon.ico",
      "uninstallerIcon": "assets/desktop/icon.ico",
      "include": "assets/desktop/installer.nsh"
    }
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "archiver": "^7.0.1",
    "axios": "^1.18.1",
    "better-sqlite3": "^12.11.1",
    "boxen": "^7.1.1",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "csv-parse": "^6.2.1",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "ffmpeg-static": "^5.3.0",
    "figlet": "^1.11.0",
    "flac-metadata": "^0.1.1",
    "gradient-string": "^2.0.2",
    "lru-cache": "^11.5.1",
    "music-metadata": "^11.13.0",
    "node-id3": "^0.2.9",
    "p-limit": "^7.3.0",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/archiver": "^7.0.0",
    "@types/cheerio": "^0.22.35",
    "@types/express": "^5.0.6",
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "copyfiles": "^2.4.1",
    "electron": "^40.10.0",
    "electron-builder": "^26.10.0",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "typedoc": "^0.28.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.6"
  }
}
