{
  "name": "qbz-downloader",
  "version": "5.0.0",
  "description": "Desktop-first Qobuz downloader EXE with Hi-Res audio, metadata automation, and lyrics support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "build:full": "cd client && npm install && npm run build && cd .. && npm run build",
    "clean": "rimraf dist coverage",
    "copy-assets": "copyfiles -u 1 \"src/services/dashboard/public/**/*\" dist",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "test:coverage": "npx vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "docs": "typedoc --out docs src/index.ts",
    "desktop:start": "npm run build:full && electron electron/main.cjs",
    "desktop:pack": "npm run build:full && electron-builder --dir",
    "desktop:dist": "npm run build:full && electron-builder --win nsis",
    "desktop:dist:portable": "npm run build:full && electron-builder --win portable",
    "desktop:dist:all": "npm run build:full && electron-builder --win nsis portable",
    "prepare": "husky"
  },
  "keywords": [
    "qobuz",
    "downloader",
    "hi-res",
    "flac",
    "music",
    "metadata",
    "lyrics",
    "lossless",
    "audio",
    "music-downloader",
    "hifi",
    "desktop-app",
    "electron",
    "windows-exe"
  ],
  "author": "ifauzeee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ifauzeee/QBZ-Downloader.git"
  },
  "bugs": {
    "url": "https://github.com/ifauzeee/QBZ-Downloader/issues"
  },
  "homepage": "https://github.com/ifauzeee/QBZ-Downloader#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "build": {
    "appId": "com.ifauze.qbzdownloader",
    "productName": "QBZ Downloader",
    "directories": {
      "output": "release",
      "buildResources": "assets/desktop"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/desktop/**/*",
      "node_modules/**/*",
      "package.json",
      "LICENSE",
      "README.md"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "asarUnpack": [
      "**/*.node",
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/desktop/icon.ico",
      "artifactName": "QBZ-Downloader-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "QBZ-Downloader-Portable-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ifauzeee",
        "repo": "QBZ-Downloader",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/desktop/icon.ico",
      "uninstallerIcon": "assets/desktop/icon.ico"
    }
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "archiver": "^7.0.1",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.6.0",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "cheerio": "^1.1.2",
    "electron-updater": "^6.6.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "figlet": "^1.7.0",
    "flac-metadata": "^0.1.1",
    "gradient-string": "^2.0.2",
    "music-metadata": "^11.10.6",
    "node-id3": "^0.2.6",
    "p-limit": "^7.2.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/cheerio": "^0.22.35",
    "@types/express": "^5.0.6",
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/coverage-v8": "^4.1.5",
    "copyfiles": "^2.4.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "prettier": "^3.1.0",
    "supertest": "^7.2.2",
    "typedoc": "^0.27.9",
    "typescript": "~5.7.3",
    "vitest": "^4.0.16"
  }
}
