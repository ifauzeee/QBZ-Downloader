# ==============================================================================
# 🎵 QBZ-Downloader | Configuration Template
# ==============================================================================
# This application uses the Qobuz API but is not certified by Qobuz.
# ==============================================================================

# --- [ 🔐 AUTHENTICATION ] ---
# Fill these with your Qobuz API credentials
QOBUZ_APP_ID=
QOBUZ_APP_SECRET=
QOBUZ_USER_AUTH_TOKEN=
QOBUZ_USER_ID=

# Optional Spotify credentials for migration
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- [ 📥 DOWNLOAD CORE ] ---
DOWNLOADS_PATH=./downloads
DEFAULT_QUALITY=27
MAX_CONCURRENCY=2
RETRY_ATTEMPTS=3
RETRY_DELAY=1000
BANDWIDTH_LIMIT=0

# --- [ 📁 NAMING & STRUCTURE ] ---
# Variables: {title}, {artist}, {album}, {albumArtist}, {track_number}, {year}
FOLDER_TEMPLATE={albumArtist}/{album}
FILE_TEMPLATE={track_number}. {title}

# --- [ 🏷️ METADATA & ARTWORK ] ---
EMBED_COVER_ART=true
SAVE_COVER_FILE=true
COVER_SIZE=max

# --- [ 🎤 LYRICS ] ---
DOWNLOAD_LYRICS=true
EMBED_LYRICS=true
SAVE_LRC_FILE=true
LYRICS_TYPE=both

# --- [ 🖥️ DASHBOARD ] ---
DASHBOARD_PORT=3000
DASHBOARD_PASSWORD=

# --- [ 📡 MEDIA SERVER INTEGRATION ] ---
# Supported types: plex, jellyfin, webhook, none
MEDIA_SERVER_ENABLED=false
MEDIA_SERVER_TYPE=none
MEDIA_SERVER_URL=
MEDIA_SERVER_TOKEN=
MEDIA_SERVER_LIBRARY_ID=

# --- [ 📤 MULTI-FORMAT EXPORT ] ---
# Automatically convert FLAC to other formats after download
EXPORT_ENABLED=false
EXPORT_FORMAT=mp3
EXPORT_BITRATE=320k
EXPORT_KEEP_ORIGINAL=true
EXPORT_PATH=

# --- [ 🌐 NETWORK ] ---
STREAMING_QUALITY=5
