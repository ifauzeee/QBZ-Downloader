                        style={{
                          padding: '10px 16px',
                          fontSize: '14px',
                          minWidth: '85px',
                          display: 'flex',
                          alignItems: 'center',
                          justifyContent: 'center',
                          gap: '8px',
                          height: '44px'
                        }}
                        title="Change Language"
                      >
                        {(() => {
                          const config = flags[language] || flags.en;
