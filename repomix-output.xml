                    color={data.duplicates > 0 ? 'var(--danger)' : 'var(--success)'}
                    delay={0.5}
                />
            </div>

            <motion.div 
                variants={itemVariants}
                className="action-banner-premium"
                style={{ 
                    position: 'relative',
                    background: 'linear-gradient(135deg, #2dd4bf 0%, #06b6d4 50%, #6366f1 100%)', 
                    borderRadius: '32px', 
