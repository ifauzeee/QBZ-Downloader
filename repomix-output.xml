                                >
                                    <div className="quality-label">{opt.label}</div>
                                    <div className="quality-detail">{opt.detail}</div>
                                </div>
                            ))}
                        </div>
                    </div>

                    {/* Options Section */}
                    <div className="config-section">
                        <label className="section-label">Options</label>
                        <div
