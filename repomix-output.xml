}

const HistoryRow = React.memo(({ item, virtualItem, downloadFile, confirmDelete, t }: { item: HistoryItem, virtualItem: any, downloadFile: (id: string) => void, confirmDelete: (id: string) => void, t: (key: string) => string }) => {
    return (
        <div
            className="list-row"
