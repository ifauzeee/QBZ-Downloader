                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                }
                .header-title { display: flex; alignItems: center; gap: 12px; }
                .header-title h3 { margin: 0; font-size: 1.2rem; font-weight: 700; }
                .unread-badge {
                    background: var(--accent);
                    color: white;
                    padding: 2px 8px;
                    border-radius: 10px;
                    font-size: 0.7rem;
