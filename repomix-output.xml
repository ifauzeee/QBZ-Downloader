        );

        this.updateDailyStats('albums');
    }

    getAlbum(id: string): DbAlbum | undefined {
        const db = this.getDb();
        return db.prepare('SELECT * FROM albums WHERE id = ?').get(id) as DbAlbum | undefined;
    }

    getAllAlbums(limit = 50, offset = 0): DbAlbum[] {
